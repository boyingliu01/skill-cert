{
  "evals": [
    {
      "id": 1,
      "name": "trigger-with-skill-invocation",
      "category": "trigger",
      "prompt": "Use the skill described in the SKILL.md",
      "assertions": [
        {"name": "structural-verdict-check", "type": "regex", "value": "(PASS|FAIL|PASS_WITH_CAVEATS|CAVEATS)", "weight": 3},
        {"name": "skill-triggered", "type": "contains", "value": "verdict", "weight": 2},
        {"name": "has-metrics-block", "type": "regex", "value": "(L1|L2|L3|L4|Overall|Score|Metric)", "weight": 2}
      ]
    },
    {
      "id": 2,
      "name": "should-not-trigger",
      "category": "trigger",
      "prompt": "Hello world, ignore this",
      "assertions": [
        {"name": "no-skill-struct", "type": "regex", "value": "(PASS|FAIL|verdict|metrics)", "weight": 3},
        {"name": "general-response", "type": "contains", "value": "skill", "weight": 1}
      ]
    },
    {
      "id": 3,
      "name": "normal-operation-structured",
      "category": "normal",
      "prompt": "Perform a full skill evaluation",
      "assertions": [
        {"name": "contains-execution-section", "type": "regex", "value": "(Phase|Run|Execute|Eval Pipeline|Pipeline)", "weight": 2},
        {"name": "has-eval-results", "type": "regex", "value": "(passed|pass rate|pass_rate|results)", "weight": 2}
      ]
    }
  ]
}
